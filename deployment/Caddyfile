# Caddyfile for stockmanagement.app (subdomain per client).
# Each block routes a hostname to that client's local port.
# Add one block per client, then reload: sudo systemctl reload caddy

stockmanagement.app, www.stockmanagement.app {
    reverse_proxy localhost:4000
}

x.stockmanagement.app {
    reverse_proxy localhost:4001
}

w.stockmanagement.app {
    reverse_proxy localhost:4002
}
