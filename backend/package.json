{
  "name": "stock-management-backend",
  "version": "1.0.0",
  "description": "Backend for Stock Management System",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "init-db": "node database/init.js",
    "cleanup-db": "node database/cleanup.js",
    "reset-db": "node database/reset.js",
    "clear-stock": "node database/clearStock.js",
    "seed-login": "node database/seedLoginUsers.js",
    "import-data": "node database/import.js",
    "seed-custom": "node database/seed_custom.js",
    "remove-touriya": "node database/removeTouriya.js",
    "reset-vouchers": "node database/resetVouchers.js",
    "reset-stock": "node database/clearStock.js",
    "reset-all": "node database/resetAll.js",
    "backup": "node database/backup.js",
    "backup:weekly": "node database/backup.js weekly",
    "backup:list": "node database/backup.js list",
    "backup:restore": "node database/backup.js restore",
    "migrate": "node database/migrate.js up",
    "migrate:status": "node database/migrate.js status",
    "migrate:down": "node database/migrate.js down",
    "migrate:create": "node database/migrate.js create",
    "cleanup:dry": "node database/cleanup.js --dry-run --all",
    "cleanup:daily": "node database/cleanup.js --run",
    "cleanup:weekly": "node database/cleanup.js --run --weekly",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop stock-management-api",
    "pm2:restart": "pm2 restart stock-management-api",
    "pm2:logs": "pm2 logs stock-management-api"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "node-cron": "^4.2.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4",
    "vitest": "^1.6.1"
  }
}
