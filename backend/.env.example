# ============================================
# Stock Management System - Configuration
# Copy this file to .env and adjust values
# ============================================

# Server
PORT=4000

# Database path (default: ./database/stock_management.db)
# DB_PATH=./database/stock_management.db

# Backup settings
# BACKUP_DIR=./database/backups
DAILY_BACKUP_RETENTION=7       # Keep 7 daily backups
WEEKLY_BACKUP_RETENTION=4      # Keep 4 weekly backups

# Cleanup retention (days before archiving)
AUDIT_RETENTION_DAYS=90        # Archive audit logs older than 90 days
ORDER_RETENTION_DAYS=180       # Archive completed/cancelled orders older than 180 days

# Archive directory (for exported archive files)
# ARCHIVE_DIR=./database/archives

# Scheduler (set to false to disable automatic backup jobs)
SCHEDULER_ENABLED=true

# Automatic cleanup is OFF by default — all logs and data are kept forever.
# Set to true only if the database gets too large and the app slows down.
CLEANUP_ENABLED=false

# Cron schedules (override defaults)
# DAILY_BACKUP_CRON=0 2 * * *       # Daily backup at 2:00 AM
# WEEKLY_BACKUP_CRON=0 3 * * 0      # Weekly backup Sunday 3:00 AM
# DAILY_CLEANUP_CRON=0 4 * * *      # Daily cleanup at 4:00 AM
# WEEKLY_CLEANUP_CRON=0 5 * * 0     # Weekly cleanup Sunday 5:00 AM
